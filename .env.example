# SOGo MCP connector — configuration
# Copy to .env and fill in. Only the first three are required.

# SOGo server hostname (no scheme)
SOGO_HOST=mail.example.com

# Full login (usually your email address) and password
SOGO_USERNAME=you@example.com
SOGO_PASSWORD=your_password

# --- Optional overrides (sensible defaults derived from SOGO_HOST) ---
# IMAP_HOST=mail.example.com
# IMAP_PORT=993
# SMTP_HOST=mail.example.com
# SMTP_PORT=587            # 587 = STARTTLS, 465 = implicit TLS
# SMTP_SECURE=false        # set true only for port 465
# SOGO_DAV_URL=https://mail.example.com/SOGo/dav
# SOGO_FROM=you@example.com

# Set to true ONLY if your server uses a self-signed certificate
# SOGO_ALLOW_INSECURE_TLS=false
